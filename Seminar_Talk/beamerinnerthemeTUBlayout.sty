\ProvidesPackage{beamerinnerthemeTUBlayout}[2015/11/04 TUB-Layout for beamer]


\mode<presentation>
\geometry{left=0.95cm, right=0.95cm}

% frametitle
\setbeamercolor{frametitle}{fg=title,bg=white}
\defbeamertemplate*{frametitle}{customized}[1][]{} %create empty frametitle
\addtobeamertemplate{frametitle}{%
	\vspace{0pt}\hspace{0pt}\insertframetitle }

% table of content
\defbeamertemplate*{toc}{customized}[1][]{} %create empty title page
\addtobeamertemplate{toc}{%
	\addtobeamertemplate{section in toc}{TUBlayout}{\leftskip=0.5em\large\inserttocsection\par}
}

% block
\setbeamercolor{block title}{fg=TUred,bg=white}
\setbeamercolor{block body}{fg=black,bg=white}

% itemize
\setbeamercolor{structure}{fg=title,bg=white}
\setbeamertemplate{itemize item}[triangle]

% navigation
\setbeamercolor{section in head/foot}{fg=TUred,bg=white}
\setbeamercolor{subsection in head/foot}{fg=TUred,bg=white}
\setbeamercolor{frametitle}{fg=title,bg=white}

\setbeamercolor{headline}{fg=white,bg=TUlightgrey}
\setbeamercolor{footline}{fg=white,bg=}

% background
\setbeamercolor{background canvas}{fg=white, bg=background}

\mode<all>
