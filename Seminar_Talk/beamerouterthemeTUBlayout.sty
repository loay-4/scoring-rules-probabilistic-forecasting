      \begin{pgfpicture}
        \pgfpathrectangle{\pgfpointorigin}{\pgfpoint{\paperwidth}{10pt}}
        \pgfusepath{clip}
        \pgftext[left,base]{\pgfuseshading{TUshading}{45}}
      \end{pgfpicture}
    };
    \node[anchor=south,text width=0.98\paperwidth] at (current page.south) {
      \insertshortauthor \pipe \insertshortinstitute \pipe {\textit\insertshorttitle} \hfill \insertframenumber \hspace{1em}
    };
  \end{tikzpicture}
}
