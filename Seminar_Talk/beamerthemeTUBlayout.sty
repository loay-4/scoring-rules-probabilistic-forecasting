\ProvidesPackage{beamerthemeTUBlayout}[2015/11/04 TUB-Layout for beamer]

\mode<presentation>

\RequirePackage{tikz}

% definitions of TU styleguide colors
\definecolor{TUred}{RGB}{196,13,30}
\definecolor{TUgrey}{RGB}{67,67,67}
\definecolor{TUlightgrey}{RGB}{178,178,178}
\definecolor{TUorange}{RGB}{255,108,0}
\definecolor{TUgrey}{RGB}{67,67,67}
\definecolor{TUblue}{RGB}{31,144,204}
\definecolor{TUviolet}{RGB}{144,19,254}
\definecolor{TUgreen}{RGB}{73,203,64}
\definecolor{TUblack}{RGB}{0,0,0}

\definecolor{bggrey}{RGB}{230,230,230}

%%% Choose background color for slides. 
% Recommendations: bggrey, white
\colorlet{background}{white}

%%% Choose title and accent color used for the slides
% Default recommendation: TUred
% otherwise choose in accordance with the selected color style
\colorlet{title}{TUred}

%%% Choose one of the color styles according the the TU corporate design templates below

%%% TU unicolor red
\pgfdeclarehorizontalshading{TUshading}{\paperwidth}{
  color(0pt)=(TUred);
  color(\paperwidth)=(TUred)
}

